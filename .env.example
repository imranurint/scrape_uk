# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=uni_scraper
DB_USER=scraper
DB_PASSWORD=scraper_pass
DATABASE_URL=postgresql+asyncpg://scraper:scraper_pass@localhost:5432/uni_scraper

# ─── Proxy Rotation (optional) ───────────────────────────────────────────────
# Leave empty to disable proxy support
# PROXY_LIST=http://user:pass@host:port

# ─── Crawl4AI / LLM (optional) ───────────────────────────────────────────────
# Only needed if USE_AI_EXTRACTOR=true
OPENAI_API_KEY=

# Set to "true" to enable Crawl4AI fallback on unstructured pages
USE_AI_EXTRACTOR=false

# ─── Scrapy Settings ─────────────────────────────────────────────────────────
SCRAPY_CONCURRENT_REQUESTS=16
SCRAPY_DOWNLOAD_DELAY=1.5
SCRAPY_LOG_LEVEL=INFO
